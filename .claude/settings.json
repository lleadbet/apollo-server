{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/changeset-reminder.sh --format claude",
            "if": "Bash(git commit*)",
            "statusMessage": "Checking for changeset..."
          }
        ]
      }
    ]
  }
}
